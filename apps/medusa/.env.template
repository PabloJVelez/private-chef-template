DB_NAME=chef-template
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/${DB_NAME}
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/${DB_NAME}

STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
AUTH_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

ADMIN_BACKEND_URL=http://localhost:9000
# Admin app URL (for Stripe Connect account links); required when using Stripe Connect onboarding
MEDUSA_ADMIN_URL=http://localhost:7000

# Add your own Stripe secret key here
STRIPE_API_KEY=
# Stripe payment webhook secret (payment intents, etc.)
# STRIPE_WEBHOOK_SECRET=
# Stripe Connect account.updated webhook secret (for onboarding sync)
# STRIPE_CONNECT_WEBHOOK_SECRET=
# Set to true to use Stripe Connect (destination charges); requires onboarding in admin
# USE_STRIPE_CONNECT=false
# Refund application fee when refunding Connect charges
# REFUND_APPLICATION_FEE=false

# Sentry configuration
# Find your DSN in Sentry: Settings → Projects → <your project> → Client Keys
SENTRY_DSN=
# Optional: only required if you plan to enable Sentry webhooks
# SENTRY_API_TOKEN=
